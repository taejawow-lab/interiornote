---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Newsletter" description="Get renter-friendly room plans, small-space measurements, and practical interior notes in your inbox."><section class="newsletter-hero section"><div class="wrap" style="display:grid;grid-template-columns:minmax(0,1fr) minmax(280px,420px);gap:clamp(28px,5vw,70px);align-items:center"><div><p class="eyebrow">Interior Note dispatch</p><h1 class="balance" style="font-size:clamp(2.5rem,6vw,4.5rem);color:#fff;margin-top:12px">One room problem. One measured plan. No showroom fantasy.</h1><p class="lede" style="color:rgba(255,255,255,.78);margin-top:22px">A concise weekly note for renters and small-space dwellers: what to measure, what to avoid, and which upgrades are actually reversible.</p></div><form class="search-panel" data-news-form style="background:rgba(255,255,255,.96)"><h2 style="font-size:1.6rem;margin-bottom:8px">Join the room-notes list</h2><p style="color:var(--sage);margin-bottom:18px">No spam, no renovation pressure, no landlord-risky advice.</p><label class="eyebrow" for="email">Email</label><input id="email" type="email" required placeholder="you@example.com" style="width:100%;margin:8px 0 14px;border:1px solid var(--line);border-radius:12px;padding:14px 15px" /><button class="btn btn-primary" type="submit" style="width:100%;justify-content:center">Subscribe</button><p style="font-size:.86rem;color:var(--sage-soft);margin-top:14px">You can unsubscribe anytime. We use this only to send Interior Note updates.</p></form></div></section></BaseLayout>
