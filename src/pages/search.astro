---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
const posts = (await getCollection('posts')).filter((post) => !post.data.draft).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const categories = [...new Set(posts.map((p) => p.data.category).filter(Boolean))].slice(0, 10);
const searchIndex = posts.map((post) => ({ title: post.data.title, description: post.data.description, category: post.data.category || 'general', tags: post.data.tags || [], url: `/posts/${post.slug}/`, date: post.data.pubDate?.toISOString?.().slice(0, 10) || '' }));
---
<BaseLayout title="Search" description="Search Interior Note room plans by room, constraint, product, or renter-friendly requirement."><section class="section"><div class="wrap"><p class="eyebrow">Search the archive</p><h1 class="balance" style="font-size:clamp(2.4rem,6vw,4.4rem);max-width:12ch">Find a room plan.</h1><p class="lede" style="margin-top:18px;max-width:58ch">Filter source-checked interiors guidance by category, room size, and renter-safe constraints. Everything runs locally in your browser.</p><div class="search-panel" style="margin-top:32px"><label for="site-search" class="eyebrow">Search query</label><input id="site-search" data-search-input type="search" placeholder="Try storage, glare, curtains, humidity..." autocomplete="off" style="width:100%;margin-top:10px;border:1px solid var(--line);border-radius:12px;background:var(--paper);padding:15px 16px;font-size:1.1rem;outline:none" /><div class="filter-chips" style="margin-top:18px">{categories.map((cat) => <button class="chip facet-opt" type="button" data-val={cat.toLowerCase()}>{cat}</button>)}</div><p style="margin-top:16px;color:var(--sage-soft)"><b id="search-result-count">{posts.length}</b> matching guides</p></div><div id="search-results" class="card-grid" style="margin-top:34px" aria-live="polite"></div><p data-empty style="display:none;margin-top:24px;color:var(--sage-soft)">No matching room notes yet. Try a broader room or product term.</p></div></section><script type="application/json" id="search-index" set:html={JSON.stringify(searchIndex)} /><script is:inline>const input=document.querySelector('[data-search-input]'),results=document.getElementById('search-results'),count=document.getElementById('search-result-count'),empty=document.querySelector('[data-empty]'),index=JSON.parse(document.getElementById('search-index').textContent||'[]'),active=new Set();function esc(s){return String(s||'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}function render(){const q=String(input.value||'').toLowerCase().trim().split(/\s+/).filter(Boolean);const items=index.filter(item=>{const hay=[item.title,item.description,item.category,...(item.tags||[])].join(' ').toLowerCase();const qOk=!q.length||q.every(t=>hay.includes(t));const fOk=!active.size||[...active].some(f=>String(item.category||'').toLowerCase()===f||(item.tags||[]).map(x=>String(x).toLowerCase()).includes(f));return qOk&&fOk;});results.innerHTML=items.slice(0,36).map(item=>`<article class="card"><a href="${item.url}"><div class="card-body"><div class="card-meta"><span>${esc(item.category)}</span><span>${esc(item.date)}</span></div><h3 class="card-title">${esc(item.title)}</h3><p class="card-desc">${esc(item.description)}</p><div class="card-foot"><span>Open guide</span><span>→</span></div></div></a></article>`).join('');count.textContent=items.length;empty.style.display=items.length?'none':'';}document.querySelectorAll('.facet-opt').forEach(btn=>btn.addEventListener('click',()=>{const v=btn.dataset.val;active.has(v)?active.delete(v):active.add(v);btn.classList.toggle('active');render();}));input.addEventListener('input',render);render();</script></BaseLayout>
