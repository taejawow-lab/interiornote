---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
const posts = (await getCollection('posts')).filter((post) => !post.data.draft).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = posts.slice(0, 5); const recentPosts = posts.slice(5, 13);
const categories = [...new Set(posts.map((p) => p.data.category).filter(Boolean))].slice(0, 8);
const siteDescription = import.meta.env.PUBLIC_SITE_DESCRIPTION || 'Renter-friendly interiors, small-space layouts, and practical product decisions.';
const heroImage = featuredPosts[0]?.data.heroImage || '/images/og-default.png';
---
<BaseLayout title="Home" description={siteDescription}>
  <section class="hero"><div class="wrap hero-grid"><div><p class="eyebrow">Small-space field notes</p><h1 class="balance">Rooms that work before they look <em>finished</em>.</h1><p class="lede pretty">Interior Note turns compact apartments, rentals, and awkward corners into measurable plans: clearance, light, storage, humidity, noise, and no-damage upgrades first.</p><div class="hero-cta"><a class="btn btn-primary" href="/posts/">Browse guides</a><a class="btn btn-ghost" href="/search/">Search by room</a></div><div class="hero-trust"><div class="av"><span></span><span></span><span></span><span></span></div><span>{posts.length} source-checked guides · renter-safe decisions · real room constraints</span></div></div><div class="hero-visual" aria-hidden="true"><img class="main-ph" src={heroImage} alt="" loading="eager" decoding="async" /><div class="float-card fc-1"><span class="fc-ic">⌂</span><div><div class="fc-t">Renter-safe first</div><div class="fc-s">No-drill / low-risk plans</div></div></div><div class="float-card fc-2"><span class="fc-ic">↔</span><div><div class="fc-t">Clearance checked</div><div class="fc-s">Small-room measurements</div></div></div></div></div></section>
  <section class="section-tight"><div class="wrap"><div class="browse-bar"><h2>Filter by room problem</h2><button class="chip active" data-filter-group="room" data-filter="all">All</button><button class="chip" data-filter-group="room" data-filter="storage">Storage</button><button class="chip" data-filter-group="room" data-filter="lighting">Lighting</button><button class="chip" data-filter-group="room" data-filter="renter">Renter</button><button class="chip" data-filter-group="room" data-filter="small">Small space</button></div><div class="card-grid feature">{featuredPosts.map((post, i) => <ArticleCard title={post.data.title} description={post.data.description} href={`/posts/${post.slug}/`} image={post.data.heroImage} category={post.data.category} pubDate={post.data.pubDate} tags={post.data.tags} variant={i === 0 ? 'feature' : 'standard'} index={i} />)}</div></div></section>
  <section class="section"><div class="wrap"><div class="promise"><p class="eyebrow">The Interior Note promise</p><h2 class="balance" style="font-size:clamp(1.9rem,4vw,3rem);margin-top:10px">Pretty is not enough. Every guide has to survive a lease, a budget, and a tape measure.</h2><div class="promise-grid"><div class="promise-item"><div class="pi-ic">✓</div><h3>Renter-friendly gates</h3><p>No-damage and reversible options are labeled before you buy or drill.</p></div><div class="promise-item"><div class="pi-ic">↔</div><h3>Real dimensions</h3><p>Clearance, cord paths, airflow, glare, and storage depth are treated as design requirements.</p></div><div class="promise-item"><div class="pi-ic">$</div><h3>Budget clarity</h3><p>We separate low-cost layout changes from product purchases and affiliate suggestions.</p></div></div></div></div></section>
  <section class="section-tight"><div class="wrap"><div class="section-head"><div class="sh-left"><p class="eyebrow">Latest notes</p><h2>Recent room plans</h2></div><a class="sh-link" href="/posts/">View archive →</a></div><div class="guide-list">{recentPosts.map((post, i) => <a class="guide-row" href={`/posts/${post.slug}/`}><span class="g-num">{String(i + 1).padStart(2, '0')}</span><span class="g-body"><span class="g-cat">{post.data.category}</span><span class="g-title">{post.data.title}</span></span><span class="g-time">{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span></a>)}</div></div></section>
  <section class="section-tight"><div class="wrap"><div class="section-head"><div class="sh-left"><p class="eyebrow">Browse</p><h2>Categories</h2></div><a class="sh-link" href="/categories/">All categories →</a></div><div class="filter-chips">{categories.map((cat) => <a class="chip" href={`/category/${cat.toLowerCase().trim().replace(/\s+/g, '-')}/`}>{cat}</a>)}</div></div></section>
</BaseLayout>
