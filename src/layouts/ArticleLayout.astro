---
import BaseLayout from './BaseLayout.astro';
import References from '../components/References.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
export interface Props { title: string; description: string; pubDate: Date; updatedDate?: Date; heroImage?: string; tags?: string[]; category?: string; sources?: Array<{ title: string; url: string; author?: string; year?: string }>; affiliate?: boolean; visualsCount?: number; hasVideo?: boolean; headings?: Array<{ depth: number; slug: string; text: string }>; faq?: Array<{ question: string; answer: string }>; internalLinks?: string[]; }
const { title, description, pubDate, updatedDate, heroImage, tags = [], category, sources = [], affiliate = false, visualsCount = 0, hasVideo = false, headings = [], faq = [], internalLinks = [] } = Astro.props;
const siteUrl = (Astro.site ? Astro.site.toString().replace(/\/$/, '') : (import.meta.env.PUBLIC_SITE_URL || 'https://interiornote.org'));
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'interiornote';
const postUrl = `${siteUrl}${Astro.url.pathname}`;
const categorySlug = category ? category.toLowerCase().trim().replace(/\s+/g, '-') : '';
const readMinutes = Math.max(4, Math.round((description.length + title.length) / 150) + 6);
const saveId = Astro.url.pathname.replace(/^\/posts\//, '').replace(/\/$/, '') || title.toLowerCase().replace(/[^a-z0-9]+/g, '-');
const articleSchema = { '@type': 'Article', headline: title, description, image: heroImage, datePublished: pubDate?.toISOString(), dateModified: (updatedDate || pubDate)?.toISOString(), author: { '@type': 'Organization', name: `${siteName} Editorial Team`, url: siteUrl }, publisher: { '@type': 'NewsMediaOrganization', name: siteName, url: siteUrl } };
const breadcrumbSchema = { '@type': 'BreadcrumbList', itemListElement: [ { '@type': 'ListItem', position: 1, name: siteName, item: `${siteUrl}/` }, ...(category ? [{ '@type': 'ListItem', position: 2, name: category, item: `${siteUrl}/category/${categorySlug}/` }] : []), { '@type': 'ListItem', position: category ? 3 : 2, name: title, item: postUrl } ] };
const faqSchema = faq.length ? { '@type': 'FAQPage', mainEntity: faq.map((q) => ({ '@type': 'Question', name: q.question, acceptedAnswer: { '@type': 'Answer', text: q.answer } })) } : null;
const schema = { '@context': 'https://schema.org', '@graph': faqSchema ? [articleSchema, breadcrumbSchema, faqSchema] : [articleSchema, breadcrumbSchema] };
---
<BaseLayout title={title} description={description} image={heroImage} type="article" publishedTime={pubDate?.toISOString()} modifiedTime={(updatedDate || pubDate)?.toISOString()} schema={schema}>
  <div class="progress" data-reading-progress></div>
  <article>
    <section class="article-hero wrap">
      <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg>{category && <a href={`/category/${categorySlug}/`}>{category}</a>}</nav>
      <div class="article-head"><div class="badge-row">{category && <span class="badge">{category}</span>}<span class="badge muted">Renter aware</span>{tags.slice(0, 2).map((tag) => <span class="badge muted">{tag}</span>)}</div><h1 class="balance">{title}</h1><p class="lede pretty">{description}</p><div class="article-meta"><div class="author"><span class="av"></span><span><span class="a-name">Interior Note Editorial</span><span class="a-sub">Measured room decisions</span></span></div><span class="m-sep"></span><span class="m-item"><b>{pubDate?.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</b>Published</span><span class="m-item"><b>{readMinutes} min</b>Reading time</span><span class="m-item"><b>{sources.length}</b>Sources</span><div class="meta-actions"><button class="icon-btn save-btn" data-save={saveId} type="button" aria-label="Save article"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21 12 17 5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg></button><button class="btn btn-ghost" data-share-url={postUrl} type="button">Share</button></div></div></div>
      {heroImage && <figure class="hero-figure"><img class="ph" src={heroImage} alt={title} loading="eager" decoding="async" /></figure>}
    </section>
    {affiliate && <div class="wrap"><AffiliateDisclosure /></div>}
    <div class="wrap article-layout"><div class="article-main article-body"><slot />{sources.length > 0 && <References sources={sources} />}</div><aside class="aside"><div class="aside-card"><h4>Fast facts</h4><ul class="fast-facts"><li><span>Visuals</span><span>{visualsCount || '5+'}</span></li><li><span>Sources</span><span>{sources.length}</span></li><li><span>Renter lens</span><span>Yes</span></li>{hasVideo && <li><span>Video</span><span>Included</span></li>}</ul></div>{headings.length > 0 && <div class="aside-card toc"><h4>Room plan</h4>{headings.filter((h) => h.depth <= 3).slice(0, 9).map((h) => <a href={`#${h.slug}`}>{h.text}</a>)}</div>}</aside></div>
    {internalLinks.length > 0 && <section class="wrap section-tight"><div class="section-head"><div class="sh-left"><p class="eyebrow">Continue planning</p><h2>Related room notes</h2></div></div><div class="related-grid-simple">{internalLinks.map((link) => <a class="guide-row" href={link}><span class="g-num">→</span><span class="g-title">Open related guide</span></a>)}</div></section>}
  </article>
</BaseLayout>
