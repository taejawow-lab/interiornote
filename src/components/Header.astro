---
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'interiornote';
const navItems = [
  { label: 'Small Spaces', href: '/category/small-spaces/' },
  { label: 'Interior Design', href: '/category/interior-design/' },
  { label: 'Archive', href: '/posts/' },
  { label: 'Search', href: '/search/' },
  { label: 'Newsletter', href: '/newsletter/' },
];
const mark = '<svg class="mark" viewBox="0 0 36 36" fill="none" aria-hidden="true"><rect x="2.5" y="2.5" width="31" height="31" rx="7.5" fill="#EDE6D6"/><path d="M20.5 3 H33 V16.5 H20.5 Z" fill="#5E7261" opacity=".24"/><rect x="2.5" y="2.5" width="31" height="31" rx="7.5" stroke="#1C2A22" stroke-width="2"/><path d="M20.5 3 V16.5 H33" stroke="#1C2A22" stroke-width="2" stroke-linejoin="round"/><path d="M6.5 22 a9.5 9.5 0 0 0 9 9.3" stroke="#1C2A22" stroke-width="1.7" fill="none" stroke-linecap="round"/><circle cx="26.7" cy="9.6" r="1.8" fill="#1C2A22"/></svg>';
---
<header class="site-header"><div class="wrap-wide nav"><a class="brand" href="/" aria-label={`${siteName} home`}><Fragment set:html={mark} /><span class="wordmark">interior<b>note</b></span></a><nav class="nav-links" aria-label="Primary navigation">{navItems.map((item) => <a href={item.href}>{item.label}</a>)}</nav><div class="nav-right"><a class="icon-btn" href="/search/" aria-label="Search Interior Note"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg></a><a class="icon-btn" href="/saved/" aria-label="Saved notes"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21 12 17 5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg><span class="count" data-save-count>0</span></a><a class="btn btn-primary" href="/newsletter/">Get room notes</a><button class="icon-btn nav-toggle" type="button" aria-label="Open menu" aria-expanded="false"><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7h16M4 12h16M4 17h16"/></svg></button></div></div></header><nav class="mobile-menu" aria-label="Mobile primary navigation">{navItems.map((item) => <a href={item.href}>{item.label}</a>)}<a href="/saved/">Saved notes <span data-save-count class="count">0</span></a></nav>
