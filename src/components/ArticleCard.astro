---
export interface Props { title: string; description: string; href: string; image?: string; category?: string; pubDate: Date; readingTime?: number; variant?: 'feature' | 'standard'; index?: number; tags?: string[]; }
const { title, description, href, image, category, pubDate, variant = 'standard', index = 0, tags = [] } = Astro.props;
const dateline = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const id = href.replace(/^\/posts\//, '').replace(/\/$/, '') || title.toLowerCase().replace(/[^a-z0-9]+/g, '-');
const itemNum = String(index + 1).padStart(2, '0');
const tagText = [category, ...tags].filter(Boolean).join(' ').toLowerCase().replace(/[^a-z0-9]+/g, ' ');
---
<article class="card" data-tags={tagText}><a href={href} aria-label={title}>{image && <div class="card-media"><img src={image} alt={title} loading="lazy" decoding="async" /><div class="badge-stack">{category && <span class="badge">{category}</span>}<span class="badge muted">Renter aware</span></div><button class="save-btn" data-save={id} type="button" aria-label="Save article"><svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21 12 17 5 21V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg></button></div>}<div class="card-body"><div class="card-meta"><span>Plan {itemNum}</span><span>{dateline}</span></div><h3 class="card-title">{title}</h3><p class="card-desc">{description}</p><div class="card-foot"><span>Read guide</span><span aria-hidden="true">→</span></div></div></a></article>
