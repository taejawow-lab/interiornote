---
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'interiornote';
const description = import.meta.env.PUBLIC_SITE_DESCRIPTION || 'Renter-friendly interiors, small-space layouts, and practical product decisions.';
const currentYear = new Date().getFullYear();
---
<footer class="footer"><div class="wrap"><div class="footer-grid"><div><a class="brand" href="/" aria-label={`${siteName} home`}><svg class="footer-mark" viewBox="0 0 36 36" fill="none" aria-hidden="true"><rect x="2.5" y="2.5" width="31" height="31" rx="7.5" stroke="currentColor" stroke-width="2"/><path d="M20.5 3 V16.5 H33" stroke="currentColor" stroke-width="2"/><path d="M6.5 22 a9.5 9.5 0 0 0 9 9.3" stroke="currentColor" stroke-width="1.7" fill="none"/><circle cx="26.7" cy="9.6" r="1.8" fill="currentColor"/></svg><span class="wordmark">interior<b>note</b></span></a><p style="margin-top:18px;max-width:44ch;color:rgba(255,255,255,.74)">{description}</p></div><div><h4>Rooms</h4><a href="/category/small-spaces/">Small spaces</a><a href="/category/interior-design/">Interior design</a><a href="/posts/">All articles</a></div><div><h4>Trust</h4><a href="/about">About</a><a href="/privacy">Privacy policy</a><a href="/terms">Terms of service</a><a href="/editorial-process">Editorial process</a><a href="/editorial-standards">Editorial standards</a><a href="/privacy">Privacy policy</a><a href="/affiliate-disclosure">Affiliate disclosure</a></div><div><h4>Notes</h4><a href="/search/">Search</a><a href="/saved/">Saved notes</a><a href="/newsletter/">Newsletter</a><a href="/contact">Contact</a></div></div><div class="footer-bottom"><span>© {currentYear} {siteName}. All rights reserved.</span><span>AI-assisted, source-checked, renter-safety reviewed.</span></div></div></footer>
